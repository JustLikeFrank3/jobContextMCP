{
  "expo": {
    "name": "jobContext",
    "slug": "jobcontext",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "jobcontext",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0b1117",
    "ios": {
      "bundleIdentifier": "app.jobcontext.mobile",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.jobcontext.mobile",
      "intentFilters": [
        {
          "action": "SEND",
          "category": [
            "DEFAULT"
          ],
          "data": [
            {
              "mimeType": "text/plain"
            }
          ]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0b1117"
      }
    },
    "plugins": [
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsText": true
          }
        }
      ],
      "expo-secure-store",
      "expo-notifications",
      "expo-asset",
      "expo-status-bar",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0b1117",
          "image": "./assets/icon.png",
          "imageWidth": 160
        }
      ]
    ],
    "icon": "./assets/icon.png",
    "extra": {
      "eas": {
        "projectId": "d0996a26-fa80-45fc-9de7-b43cfe095ebc"
      }
    }
  }
}
