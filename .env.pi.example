# Local k3d cluster secrets — copy to .env.pi (gitignored) and fill in.
# Everything is optional: with nothing set, the app runs with auth disabled
# and no LLM provider. Consumed by scripts/pi-deploy.sh.

# --- Entra ID (use a DEV app registration, not prod) -----------------------
# Dev app registration needs redirect URI: (Entra on the Pi needs TLS first — see docs)
# (see docs/local-cluster.md for setup steps)
PI_ENTRA_TENANT_ID=
PI_ENTRA_CLIENT_ID=
PI_ENTRA_CLIENT_SECRET=
# Your user OID, for owner-only dashboard features
PI_ENTRA_OWNER_OID=

# --- Fallback auth when Entra vars are unset --------------------------------
# Shared API key; leave empty to disable auth entirely (localhost only!)
PI_API_KEY=

# --- LLM provider ------------------------------------------------------------
# openai | foundry | ollama (empty = LLM features report unconfigured)
PI_LLM_PROVIDER=
PI_LLM_API_KEY=
PI_FOUNDRY_ENDPOINT=
PI_FOUNDRY_DEPLOYMENT=
PI_FOUNDRY_API_VERSION=

# --- Optional extras ---------------------------------------------------------
PI_OURA_CLIENT_ID=
PI_OURA_CLIENT_SECRET=
PI_APP_ENCRYPTION_KEY=
