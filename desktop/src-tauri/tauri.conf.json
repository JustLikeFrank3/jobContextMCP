{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jobContext",
  "version": "0.1.0",
  "identifier": "app.jobcontext.desktop",
  "build": {
    "frontendDist": "../splash"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "jobContext",
        "width": 1280,
        "height": 840,
        "minWidth": 900,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5QTI5RjIwRjBCMEI1MDUKUldRRnRiRHdJSitpK1pmN0c3QzU3b1pDM0szTWt3OHgxbnI0WUwxSkMrUk50bUtic2tTYkNyVDEK",
      "endpoints": [
        "https://github.com/JustLikeFrank3/jobContextMCP/releases/download/desktop-latest/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["dmg", "nsis", "msi", "appimage", "deb"],
    "category": "Productivity",
    "shortDescription": "Local-first job search copilot with MCP",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "binaries/jobcontext-backend": "binaries/jobcontext-backend"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist"
    }
  }
}
