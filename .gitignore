# User-specific configuration (contains your private paths, API keys, etc.)
# config.example.json is the committed template; all real configs are ignored.
config.json
config.*.json

# Docker environment file (contains API keys and local paths)
.env
# Other env files (deploy/staging/prod) — all contain secrets
.env.*
!.env.example
!.env.local.example
!.env.pi.example

# SQLite database + WAL sidecars — local runtime data, never for version control
*.db
*.db-shm
*.db-wal

# Runtime data — contains private application/health info
/data/*.json
!/data/*.example.json
/data/Connections.csv
/data/*.bak*
/data_dev

# Personal utility scripts (may contain real stories, paths, or data)
_log_stories.py

# Personal PDFs / docs that may land in repo root
/*.pdf

# Internal dev/ops files — not relevant to end users
CODEX_BUG_REPORT.md
CODEX_REFACTOR_TASK.md
debug_parser.py

# Python virtual environment (any name: .venv, .venv.nosync, iCloud dupes)
.venv*
__pycache__/
*.pyc
*.pyo

# Coverage — generated by CI/deploy workflow, not for repo
.coverage
coverage.xml
junit.xml
htmlcov/

# RAG index (contains embeddings of your personal data)
data/rag_embeddings.npy
data/rag_index.json
data/*_semantic_embeddings.npy
data/*_semantic_index.json

# Shareable/joke exports — not for repo
docs/branding/banner/jobcontextmcp-share.jpg
docs/branding/banner/jobcontextmcp-wingdings.jpg
docs/branding/banner/jobcontextmcp-wingdings.svg

# Generated workspace (created by setup_workspace(); contains user data)
workspace/

# Local backup tarballs (pre-migration snapshots, ad-hoc safety nets)
backups/

# macOS
.DS_Store
~/

# VS Code user settings
.vscode/settings.json

docs/jobContextMCP-FullDocs/
docs/jobContextMCP-FullDocs/02_monetization_strategy.md

# Personalized Copilot instructions (use copilot-instructions.example.md as the public template)
.github/copilot-instructions.md

# Operator scripts — contain credentials, tenant-specific logic, and private tooling
# docker-entrypoint.sh and migrate_to_sqlite.py are intentionally excluded: needed by Docker/tests
scripts/invite_beta_tester.py
scripts/send_update_email.py
scripts/sync_data_from_azure.sh
scripts/sync_data_from_production.sh
scripts/upload_workspace.sh
scripts/import_job_queue_if_empty.py
scripts/add_fitment_context_column.py
scripts/gen_demo_docs.py
scripts/generate_demo_pdfs.py

# Oura biometric data — personal, not for version control
data/oura.json
workspace/oura.json

# PyInstaller build outputs (desktop app backend sidecar)
/build/
/dist/

# Tauri shell build outputs
desktop/node_modules/
desktop/src-tauri/target/
desktop/src-tauri/gen/
desktop/src-tauri/binaries/
desktop/src-tauri/icons/
