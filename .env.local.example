# Local k3d cluster secrets — copy to .env.local (gitignored) and fill in.
# Everything is optional: with nothing set, the app runs with auth disabled
# and no LLM provider. Consumed by scripts/local-cluster.sh.

# --- Entra ID (use a DEV app registration, not prod) -----------------------
# Dev app registration needs redirect URI: http://localhost:8080/dashboard/callback
# (see docs/local-cluster.md for setup steps)
LOCAL_ENTRA_TENANT_ID=
LOCAL_ENTRA_CLIENT_ID=
LOCAL_ENTRA_CLIENT_SECRET=
# Your user OID, for owner-only dashboard features
LOCAL_ENTRA_OWNER_OID=

# --- Fallback auth when Entra vars are unset --------------------------------
# Shared API key; leave empty to disable auth entirely (localhost only!)
LOCAL_API_KEY=

# --- LLM provider ------------------------------------------------------------
# openai | foundry | ollama (empty = LLM features report unconfigured)
LOCAL_LLM_PROVIDER=
LOCAL_LLM_API_KEY=
LOCAL_FOUNDRY_ENDPOINT=
LOCAL_FOUNDRY_DEPLOYMENT=
LOCAL_FOUNDRY_API_VERSION=

# --- Optional extras ---------------------------------------------------------
LOCAL_OURA_CLIENT_ID=
LOCAL_OURA_CLIENT_SECRET=
LOCAL_APP_ENCRYPTION_KEY=
