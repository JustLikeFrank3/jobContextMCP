# ── Docker environment variables ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── MCP Transport ────────────────────────────────────────────────────────────
# stdio           → Claude Desktop invokes the container via `docker run -i`
# sse             → Listens on http://<host>:<port>/sse  (network clients)
# streamable-http → Listens on http://<host>:<port>/mcp  (newer clients)
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8000

# ── VS Code MCP client mode ──────────────────────────────────────────────────
# scripts/run_mcp.sh reads this to decide whether to invoke Docker or the
# local venv. .vscode/mcp.json always points at run_mcp.sh — flip this flag
# instead of editing JSON. CLI overrides win: `MCP_MODE=local ./scripts/run_mcp.sh`
#
# docker → docker compose run --rm -i jobcontextmcp  (default, recommended for users)
# local  → .venv/bin/python3 server.py               (faster iteration for developers)
MCP_MODE=docker

# ── Volume paths ─────────────────────────────────────────────────────────────
# Absolute path to your local resume workspace folder.
# This mounts to /workspace inside the container and must match
# the "resume_folder" value in your config.json.
RESUME_PATH=/absolute/path/to/your/resumes

# Absolute path to your LeetCode practice folder (optional).
# Leave blank or comment out if you don't use the leetcode tools.
LEETCODE_PATH=/absolute/path/to/your/LeetCodePractice

# ── Data sync (dev workspaces only) ──────────────────────────────────────────
# If you maintain TWO checkouts — a production one where you actually use the
# tool for job hunting, and a separate dev one for code changes — point this
# at the production data/ folder. scripts/sync_data_from_production.sh will
# pull fresh JSON state into your dev workspace and snapshot a backup tarball.
#
# Direction is hard-coded one-way (production → dev). Never the reverse.
# Leave blank if you only have one workspace.
#
# Example: DATA_SYNC_SOURCE=/Users/you/Library/Mobile Documents/com~apple~CloudDocs/Projects/jobContextMCP/data
# IMPORTANT: quote the value if the path contains spaces (e.g. "Mobile Documents"):
#   DATA_SYNC_SOURCE="$HOME/Library/Mobile Documents/com~apple~CloudDocs/Projects/jobContextMCP/data"
DATA_SYNC_SOURCE=

# Number of pre-sync backup tarballs to retain in backups/ (default 10).
# Older snapshots are pruned automatically after each sync run.
BACKUP_RETENTION=10

# ── HTTP transport (Phase B, transport/http) ─────────────────────────────────
# These configure the FastAPI + SSE adapter at transport/http/main.py.
# Independent of MCP_TRANSPORT above — the HTTP adapter is a separate process.

# Bind address. Default 127.0.0.1 (localhost only).
HOST=127.0.0.1

# Bind port for the HTTP adapter.
PORT=8001

# If true, overrides HOST to 0.0.0.0 (LAN / Tailscale). Default false.
# DO NOT enable without setting API_KEY.
ENABLE_REMOTE=false
# Set to true only when running behind a TLS-terminating reverse proxy (AKS nginx-ingress).
# Requires ENABLE_REMOTE=true; disables MCP SDK DNS rebinding check.
DISABLE_REBINDING_CHECK=false

# Bearer token required by all authenticated endpoints.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# If unset, the server runs with auth DISABLED and logs a warning.
API_KEY=

# Optional comma-separated CORS origins (e.g. https://chat.openwebui.local).
CORS_ORIGINS=
