{
  // MCP_MODE in .env controls dispatch: docker (default) or local
  // MCP_MODE=docker → docker compose run --rm -i jobcontextmcp
  // MCP_MODE=local  → .venv/bin/python3 server.py
  "servers": {
    "jobContextMCP": {
      "type": "stdio",
      "command": "${workspaceFolder}/scripts/run_mcp.sh",
      "args": [],
      "cwd": "${workspaceFolder}"
    }
  }
}
